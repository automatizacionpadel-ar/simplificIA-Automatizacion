{
  "id": "whatsapp-csv-sender-001",
  "name": "WhatsApp CSV Sender",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-csv-upload",
        "responseMode": "onReceived",
        "options": { "allowedOrigins": "*" }
      },
      "id": "aaaa0001-0000-0000-0000-000000000001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "whatsapp-csv-upload"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.failedNumbers = [];\n\nconst body = $input.first().json.body;\nconst contactos = body.contactos || [];\nconst mensajeTemplate = (body.mensaje && body.mensaje.trim())\n  ? body.mensaje.trim()\n  : '👋🏻Hola! Nos contactamos desde Buenos Aires Logística. 🚚 Tenemos un envío de {empresa} para entregarte.\\nQueremos avisarte que la entrega se realizará hoy entre las 16:00 y las 22:00 hs.\\nEn caso de que por cuestiones operativas no llegue a completarse dentro de ese rango, la entrega pasará automáticamente al siguiente día hábil entre las 10:30 y las 22:00 hs.\\nAgradecemos tu comprensión y quedamos atentos ante cualquier consulta 🙌';\n\nreturn contactos.map(c => {\n  let tel = String(c.telefono || '').replace(/\\D/g, '');\n  if (tel.length === 10) tel = '549' + tel;\n  return { json: { chatId: tel + '@c.us', message: mensajeTemplate.replace(/\\{empresa\\}/gi, c.nombre_empresa || '') } };\n});"
      },
      "id": "aaaa0002-0000-0000-0000-000000000002",
      "name": "Formatear Contactos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "aaaa0003-0000-0000-0000-000000000003",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [680, 300]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.currentChatId = $input.first().json.chatId;\nreturn $input.all();"
      },
      "id": "aaaa0004-0000-0000-0000-000000000004",
      "name": "Guardar ChatId",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://ws-wwebjs:3000/client/sendMessage/default",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-api-key", "value": "34d0e1f22e96ddc98de69f39295251001b7152b120dc3a72" }]
        },
        "sendBody": true,
        "specifyBody": "keypair",
        "bodyParameters": {
          "parameters": [
            { "name": "chatId", "value": "={{ $json.chatId }}" },
            { "name": "content", "value": "={{ $json.message }}" },
            { "name": "contentType", "value": "string" }
          ]
        },
        "options": { "timeout": 30000 },
        "onError": "continueRegularOutput"
      },
      "id": "aaaa0005-0000-0000-0000-000000000005",
      "name": "Enviar Mensaje WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1080, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-success",
              "leftValue": "={{ $json.success === true && !$json.error }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "aaaa0006-0000-0000-0000-000000000006",
      "name": "Fue exitoso?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1280, 300]
    },
    {
      "parameters": {
        "resume": "timeInterval",
        "resumeAmount": 45,
        "resumeUnit": "seconds",
        "options": {}
      },
      "id": "aaaa0007-0000-0000-0000-000000000007",
      "name": "Esperar 45s",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1480, 300],
      "webhookId": "aaaa00w8-0000-0000-0000-000000000008"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!Array.isArray(staticData.failedNumbers)) staticData.failedNumbers = [];\nstaticData.failedNumbers.push(staticData.currentChatId || 'desconocido');\nreturn $input.all();"
      },
      "id": "aaaa0009-0000-0000-0000-000000000009",
      "name": "Registrar Fallido",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1480, 480]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://ws-wwebjs:3000/client/info/default",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-api-key", "value": "34d0e1f22e96ddc98de69f39295251001b7152b120dc3a72" }]
        },
        "options": {}
      },
      "id": "aaaa0010-0000-0000-0000-000000000010",
      "name": "Obtener Info Propio",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [880, 100]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst failed = staticData.failedNumbers || [];\nif (failed.length === 0) return [];\n\nconst info = $input.first().json;\nconst wid = info?.info?.wid?._serialized || (info?.info?.wid?.user ? info.info.wid.user + '@c.us' : '');\nif (!wid) return [];\n\nconst lista = failed.map(n => '• ' + n).join('\\n');\nconst message = '⚠️ ' + failed.length + ' número' + (failed.length !== 1 ? 's' : '') + ' sin WhatsApp:\\n\\n' + lista;\nreturn [{ json: { chatId: wid, content: message, contentType: 'string' } }];"
      },
      "id": "aaaa0011-0000-0000-0000-000000000011",
      "name": "Preparar Resumen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
