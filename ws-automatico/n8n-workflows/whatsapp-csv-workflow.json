      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst failed = staticData.failedNumbers || [];\n\nif (failed.length === 0) return [];\n\n// Obtener chatId propio del cliente\nconst info = $input.first().json;\nconst wid = info?.info?.wid?._serialized\n  || info?.wid?._serialized\n  || info?.info?.wid?.user + '@c.us'\n  || '';\n\nif (!wid) return [];\n\nconst lista = failed.map(n => '• ' + n).join('\\n');\nconst message = '⚠️ ' + failed.length + ' número' + (failed.length > 1 ? 's' : '') + ' sin WhatsApp:\\n\\n' + lista;\n\nreturn [{ json: { chatId: wid, content: message, contentType: 'string' } }];"
      },
