            { "name": "content", "value": "={{ $json.content }}" },
            { "name": "contentType", "value": "string" }
          ]
        },
        "options": {}
      },
      "id": "aaaa0012-0000-0000-0000-000000000012",
      "name": "Enviar Resumen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1280, 100]
    }
