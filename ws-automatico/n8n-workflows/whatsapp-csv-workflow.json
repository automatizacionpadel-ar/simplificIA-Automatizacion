      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!Array.isArray(staticData.failedNumbers)) staticData.failedNumbers = [];\n\nconst item = $input.first().json;\nconst chatId = item.chatId || '';\nconst numero = chatId.replace('@c.us', '');\nstaticData.failedNumbers.push(numero);\n\nreturn $input.all();"
      },
